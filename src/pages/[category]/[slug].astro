---
// [src/pages/[category]/[slug].astro]
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar/Sidebar.astro';
import { getAllPosts } from '../../utils/getPosts';
import slugify from 'slugify';
import { getColor } from '../../utils/heroCategories';
import { resolveImagePath } from '../../utils/imagePath';
import { formatDateLong } from '../../utils/formatDate';
import { calculateReadingTime, getCategoryUrl } from '../../utils/postHelpers';
import { SITE_INFO } from '../../constants/siteConfig';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => {
    const categorySlug = slugify(post.data.category, { lower: true });
    return {
      params: { category: categorySlug, slug: post.slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await post.render();

const translateCategory = (cat: string) => SITE_INFO.categoryMapping[cat] || cat;
const dateFormatted = formatDateLong(post.data.date);
const readingTimeMinutes = calculateReadingTime(post.readingTime.words);
const categoryColor = getColor(post.data.category);
const imageSrc = resolveImagePath(post.data.image);
const categoryUrl = getCategoryUrl(post.data.category);
const koreanCategory = translateCategory(post.data.category);

// SEO 및 구조화 데이터 로직은 그대로 유지 (매우 중요!)
const siteMetadata = { url: import.meta.env.SITE || 'https://simlog.pages.dev', title: SITE_INFO.metadata.title };
const postUrl = `${siteMetadata.url}${Astro.url.pathname}`;
const fullImageSrc = imageSrc ? (imageSrc.startsWith('http') ? imageSrc : `${siteMetadata.url}${imageSrc}`) : undefined;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "image": fullImageSrc ? [fullImageSrc] : undefined,
    "datePublished": post.data.date.toISOString(),
    "articleSection": koreanCategory,
    "author": { "@type": "Organization", "name": siteMetadata.title }
  }
];
---

<BaseLayout 
  title={post.data.title} 
  description={post.excerpt} 
  image={imageSrc} 
  article={true} 
  structuredData={structuredData}
>
  <div class="article-container">
    <div class="container">
      <div class="row">
        {/* 본문 영역 */}
        <main class="col-lg-8 col-12">
          <article class="post-main">
            <header class="post-header">
              <a href={categoryUrl} class="post-category" style={`--accent: ${categoryColor}`}>
                {koreanCategory}
              </a>
              <h1 class="post-title">{post.data.title}</h1>
              <div class="post-meta">
                <time>{dateFormatted}</time>
                <span class="divider">·</span>
                <span>{readingTimeMinutes}{SITE_INFO.posts.readingTime}</span>
              </div>
            </header>

            {imageSrc && (
              <figure class="post-hero-image">
                <img src={imageSrc} alt={post.data.title} />
                {post.data.imageAttribution && (
                  <figcaption>
                    <a href={post.data.imageAttribution} target="_blank" rel="noopener">이미지 출처</a>
                  </figcaption>
                )}
              </figure>
            )}

            <div class="post-content">
              <Content />
            </div>
          </article>
        </main>

        {/* 사이드바 영역 */}
        <div class="col-lg-4 col-12">
          <Sidebar />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:inline>
  .article-container {
    background-color: #fff;
    padding: 4rem 0;
  }

  .post-main {
    padding-right: 2rem;
  }

  .post-header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .post-category {
    display: inline-block;
    color: var(--accent);
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none;
    margin-bottom: 1rem;
    padding: 4px 12px;
    background: #f8f9fa;
    border-radius: 4px;
  }

  .post-title {
    font-size: 2.8rem;
    font-weight: 800;
    color: #111;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    word-break: keep-all;
  }

  .post-meta {
    color: #888;
    font-size: 1rem;
    display: flex;
    justify-content: center;
    gap: 10px;
  }

  .post-hero-image {
    margin: 0 0 4rem 0;
    border-radius: 16px;
    overflow: hidden;
  }

  .post-hero-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
    max-height: 500px;
  }

  .post-hero-image figcaption {
    text-align: right;
    font-size: 0.8rem;
    margin-top: 10px;
  }

  .post-hero-image figcaption a { color: #ccc; text-decoration: none; }

  /* ✅ 본문 스타일링: 여기가 제일 중요합니다 */
  .post-content {
    font-size: 1.15rem;
    line-height: 1.8;
    color: #333;
  }

  .post-content p { margin-bottom: 1.8rem; }
  .post-content h2 { font-size: 1.8rem; font-weight: 700; margin: 3rem 0 1.5rem; color: #111; }
  .post-content h3 { font-size: 1.4rem; font-weight: 700; margin: 2.5rem 0 1.2rem; color: #222; }
  
  .post-content img {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    margin: 2rem 0;
  }

  .post-content ul, .post-content ol {
    margin-bottom: 1.8rem;
    padding-left: 1.5rem;
  }

  .post-content li { margin-bottom: 0.6rem; }

  .post-content blockquote {
    border-left: 4px solid #007bff;
    padding: 1rem 1.5rem;
    background: #f8f9fa;
    margin: 2rem 0;
    font-style: italic;
    border-radius: 0 8px 8px 0;
  }

  @media (max-width: 991px) {
    .post-main { padding-right: 0; }
    .post-title { font-size: 2rem; }
    .post-header { margin-bottom: 2rem; }
  }
</style>
