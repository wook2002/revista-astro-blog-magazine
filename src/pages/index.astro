---
// [src/pages/index.astro]
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import RecentPosts from '../components/RecentPosts.astro';
import { getAllPosts } from '../utils/getPosts';
import { SITE_INFO } from '../constants/siteConfig';

// 1. 모든 포스트 가져오기
const allPosts = await getAllPosts();

// 2. 날짜순 정렬
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

// 3. 최근 포스트만 슬라이스 (개수는 siteConfig에서 관리)
const recentPosts = sortedPosts.slice(0, SITE_INFO.recentPosts.count);
---

<BaseLayout 
  title={`${SITE_INFO.metadata.title} | ${SITE_INFO.metadata.tagline}`}
  description={SITE_INFO.metadata.description}
>
  {/* 1. 브랜드 정체성을 보여주는 히로 섹션 */}
  <Hero />

  {/* 2. 덕지덕지 붙어있던 Featured, Notification 삭제! */}
  {/* 오직 '최근 기록'에만 집중하게 만듭니다. */}
  <main class="main-content">
    <RecentPosts posts={recentPosts} />
  </main>
</BaseLayout>

<style is:inline>
  .main-content {
    /* 히로와 글 목록 사이의 숨통을 틔워줍니다. */
    padding-top: 2rem;
    min-height: 60vh;
  }
</style>
