---
import '../css/main.css';
import '../css/bootstrap-grid.min.css';
import '../css/pages.scss';
import '../css/components.scss';

import Navbar from '../components/Navbar.astro'; 
import Footer from '../components/Footer.astro';
import { SITE_INFO } from '../constants/siteConfig';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
  structuredData?: object | object[];
}

const { title, description, image, article, structuredData } = Astro.props;

const siteMetadata = {
  title: SITE_INFO.metadata.title,
  description: SITE_INFO.metadata.description,
  url: import.meta.env.SITE || 'https://simlog.pages.dev', 
  defaultImage: SITE_INFO.metadata.ogImage,
};

const pageTitle = title || `${siteMetadata.title} | ${SITE_INFO.metadata.tagline}`;
const pageDescription = description || siteMetadata.description;
const pageImage = image ? `${siteMetadata.url}${image}` : `${siteMetadata.url}${siteMetadata.defaultImage}`;
const pageUrl = `${siteMetadata.url}${Astro.url.pathname}`;
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    
    <title>{pageTitle}</title>

    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content={pageDescription} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@300;400;500;600;700&family=Montserrat:wght@300;400;500;600;700&family=Open+Sans:wght@300;400;500;600&family=Poppins:wght@200;300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={pageImage} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:site_name" content={siteMetadata.title} />
    
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    
    <link rel="canonical" href={pageUrl} />

    {structuredData && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
    )}
  </head>
  <body>
    <Navbar /> 
    
    <main>
      <slot />
    </main>

    <Footer />
  </body>

  {/* ✅ 전역 스타일은 맨 아래에! */}
  <style is:global>
    :root {
      /* '--sim-' 접두어를 붙여 부트스트랩과 충돌 방지 (디자인 토큰) */
      --sim-max-width: 1200px;
      --sim-gap: 1.5rem;
    }

    /* 부트스트랩의 .container 대신 사용할 '심로그 전용 컨테이너'
       !important 없이도 우선순위를 가질 수 있도록 독자적인 클래스로 정의합니다.
    */
    .sim-container {
      width: 100%;
      max-width: var(--sim-max-width);
      margin-left: auto;
      margin-right: auto;
      padding-left: var(--sim-gap);
      padding-right: var(--sim-gap);
    }

    /* 슬롯(Slot) 내부에 들어오는 이미지들이 튀어나가지 않게 기본 방어 */
    main img {
      max-width: 100%;
      height: auto;
    }
  </style>
</html>
