---
import '../css/main.css';
import '../css/bootstrap-grid.min.css';
import '../css/pages.scss';
import '../css/components.scss';

/* ✅ 방금 만든 1대장 파일을 가장 마지막에 불러옵니다. 
   그래야 위의 찌꺼기 CSS들을 자연스럽게 덮어씁니다. */
import '../css/simlog.css'; 

import Navbar from '../components/Navbar.astro'; 
import Footer from '../components/Footer.astro';
import { SITE_INFO } from '../constants/siteConfig';

const { title, description, image, article, structuredData } = Astro.props;

const siteMetadata = {
  title: SITE_INFO.metadata.title,
  url: import.meta.env.SITE || 'https://simlog.pages.dev', 
  defaultImage: SITE_INFO.metadata.ogImage,
};

const pageTitle = title || `${siteMetadata.title} | ${SITE_INFO.metadata.tagline}`;
const pageDescription = description || SITE_INFO.metadata.description;
const pageImage = image ? `${siteMetadata.url}${image}` : `${siteMetadata.url}${siteMetadata.defaultImage}`;
const pageUrl = `${siteMetadata.url}${Astro.url.pathname}`;
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{pageTitle}</title>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content={pageDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;700;800&display=swap" rel="stylesheet" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:image" content={pageImage} />
    {structuredData && <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />}
  </head>
  
  {/* 기존에 있던 지저분한 ID(#simlog-absolute-wrapper)나 <style is:global>은 
      이제 simlog.css가 다 처리하므로 완전히 삭제했습니다. 진짜 깔끔해졌죠? */}
  <body>
    <Navbar /> 
    <main><slot /></main>
    <Footer />
  </body>
</html>
