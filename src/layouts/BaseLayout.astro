---
import '../css/main.css';
import '../css/bootstrap-grid.min.css';
import '../css/pages.scss';
import '../css/components.scss';

import Navbar from '../components/Navbar.astro'; 
import Footer from '../components/Footer.astro';
import { SITE_INFO } from '../constants/siteConfig';

const { title, description, image, article, structuredData } = Astro.props;

const siteMetadata = {
  title: SITE_INFO.metadata.title,
  url: import.meta.env.SITE || 'https://simlog.pages.dev', 
  defaultImage: SITE_INFO.metadata.ogImage,
};

const pageTitle = title || `${siteMetadata.title} | ${SITE_INFO.metadata.tagline}`;
const pageDescription = description || SITE_INFO.metadata.description;
const pageImage = image ? `${siteMetadata.url}${image}` : `${siteMetadata.url}${siteMetadata.defaultImage}`;
const pageUrl = `${siteMetadata.url}${Astro.url.pathname}`;
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{pageTitle}</title>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content={pageDescription} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;700;800&display=swap" rel="stylesheet" />
    
    <meta property="og:title" content={pageTitle} />
    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:image" content={pageImage} />
    <meta property="og:url" content={pageUrl} />

    {structuredData && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
    )}
  </head>
  <body>
    <Navbar /> 
    <main><slot /></main>
    <Footer />

    {/* ✅ 깔쌈한 정렬의 핵심: 전역 컨테이너 정의 */}
    <style is:global>
      :root {
        --sim-max-width: 1200px;
        --sim-gap: 1.5rem;
      }

      /* 부트스트랩을 이기기 위해 body를 앞에 붙여 우선순위를 높였습니다 (!important 대체) */
      body .sim-container {
        width: 100%;
        max-width: var(--sim-max-width);
        margin-left: auto;
        margin-right: auto;
        padding-left: var(--sim-gap);
        padding-right: var(--sim-gap);
        display: block; /* 확실하게 블록 요소로 지정 */
      }
    </style>
  </body>
</html>
