---
import '../css/main.css';
import '../css/bootstrap-grid.min.css';
import '../css/pages.scss';
import '../css/components.scss';

import Navbar from '../components/Navbar.astro'; 
import Footer from '../components/Footer.astro';
import { SITE_INFO } from '../constants/siteConfig';

const { title, description, image, article, structuredData } = Astro.props;

const siteMetadata = {
  title: SITE_INFO.metadata.title,
  url: import.meta.env.SITE || 'https://simlog.pages.dev', 
  defaultImage: SITE_INFO.metadata.ogImage,
};

const pageTitle = title || `${siteMetadata.title} | ${SITE_INFO.metadata.tagline}`;
const pageDescription = description || SITE_INFO.metadata.description;
const pageImage = image ? `${siteMetadata.url}${image}` : `${siteMetadata.url}${siteMetadata.defaultImage}`;
const pageUrl = `${siteMetadata.url}${Astro.url.pathname}`;
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{pageTitle}</title>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content={pageDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;700;800&display=swap" rel="stylesheet" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:image" content={pageImage} />
    {structuredData && <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />}
  </head>
  <body>
    <Navbar /> 
    <main><slot /></main>
    <Footer />

    {/* ✅ 모든 섹션을 중앙으로 모으는 절대 규칙 */}
    <style is:global>
      :root {
        --sim-max-width: 1200px;
        --sim-gap: 1.5rem;
      }

      /* 'simlog-center'라는 세상에 하나뿐인 이름을 씁니다. */
      .simlog-center {
        width: 100% !important;
        max-width: var(--sim-max-width) !important;
        margin-left: auto !important;
        margin-right: auto !important;
        padding-left: var(--sim-gap) !important;
        padding-right: var(--sim-gap) !important;
        display: block !important;
      }
    </style>
  </body>
</html>
