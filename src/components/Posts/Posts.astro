---
// [src/components/Posts/Posts.astro]
import Post from './Post.astro';
import Sidebar from '../Sidebar/Sidebar.astro'; // ✅ SidebarWide 대신 Sidebar 사용

interface Props {
  posts: any[];
  title: string;
}

const { posts, title } = Astro.props;
---

<section class="category-posts-section">
  <div class="container">
    <div class="row">
      <div class="col-lg-8 col-12">
        <header class="category-header">
          <h2 class="category-title">{title}</h2>
          <div class="title-line"></div>
        </header>

        <div class="posts-list">
          {posts.map((post) => (
            <Post {...post} />
          ))}
        </div>
      </div>

      {/* ✅ 여기서도 우리가 만든 똑똑한 사이드바를 넓게 씁니다. */}
      <Sidebar isWide={true} />
    </div>
  </div>
</section>

<style is:inline>
  .category-posts-section { padding: 4rem 0; }
  .category-header { margin-bottom: 3rem; display: flex; align-items: center; gap: 20px; }
  .category-title { font-size: 2rem; font-weight: 800; color: #111; margin: 0; }
  .title-line { flex: 1; height: 1px; background: #eee; }
  .posts-list { display: flex; flex-direction: column; }
</style>
