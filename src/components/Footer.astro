---
import { Image } from 'astro:assets';
import SocialLinks from '../constants/socialLinks'
import logo from '../assets/logo.png'
import { SITE_INFO } from '../constants/siteConfig';
---

<footer class="footer-wrapper">
  <div class="footer">
    <a href="/">
      <Image
        class="footer-logo"
        src={logo}
        alt={`${SITE_INFO.title.main}${SITE_INFO.title.sub} 로고`}
        width={100}
        height={100}
      />
    </a>

    <SocialLinks client:load styleClass="footer-icons" />
    
    <div class="footer-links">
      <div>
        <a class="footer-link" href="/privacy-policy"> 
          {SITE_INFO.footer.privacyPolicy} 
        </a>
      </div>
      <div>
        <a class="footer-link" href="/terms-and-conditions">
          {SITE_INFO.footer.termsAndConditions}
        </a>
      </div>
    </div>

    <p class="footer-copyright">
      &copy;{SITE_INFO.footer.startYear} {SITE_INFO.footer.copyrightHolder}. {SITE_INFO.footer.allRightsReserved}
    </p>
  </div>
</footer>

<style>
  .footer-wrapper .footer { text-align: center; background: var(--black); padding: 1rem 0; display: block; }
  .footer-icons { display: flex; justify-content: center; line-height: 1; margin-bottom: 1.5rem; }
  .footer-icons a { font-size: 1.5rem; margin: 0 0.5rem; transition: var(--transition); }
  .footer-icons li { list-style: none; transition: var(--transition); }
  .footer-icons li:hover { transform: translateY(-10%); }
  .footer p { margin-bottom: 0; color: var(--white); text-transform: uppercase; letter-spacing: var(--spacing); }
  .footer-logo { margin: 1rem 0 1.5rem 0; width: 3rem; height: 3rem; }
  .footer-copyright { margin: 0.8rem 0 1.2rem 0; font-size: 0.9rem; }
  .footer-links { margin: 1rem 0 0.7rem 0; line-height: 1.5rem; }
  .footer-link { color: var(--white); margin-bottom: 0.5rem; text-decoration: none; font-size: 0.9rem; }
  @media screen and (max-width: 767px) { .footer-links { line-height: 2rem; } .footer { padding: 1rem; } }
</style>
