---
// [src/components/Footer.astro]
import { Image } from 'astro:assets';
import SocialLinks from '../constants/socialLinks'
import logo from '../assets/logo.png'
import { SITE_INFO } from '../constants/siteConfig';

const currentYear = new Date().getFullYear();
---

<footer class="footer-wrapper">
  <div class="footer-container">
    {/* 1. 브랜드 & 로고 섹션 */}
    <div class="footer-brand">
      <a href="/" class="footer-logo-link">
        <Image
          class="footer-logo"
          src={logo}
          alt="로고"
          width={40}
          height={40}
        />
        <div class="logo-text">
          <span class="brand-main">{SITE_INFO.title.main}</span>
          <span class="brand-sub">{SITE_INFO.title.sub}</span>
        </div>
      </a>
      <p class="footer-tagline">{SITE_INFO.metadata.tagline}</p>
    </div>

    {/* 2. 링크 섹션 (소셜 & 정책) */}
    <div class="footer-nav">
      <div class="social-wrapper">
        <SocialLinks client:load styleClass="footer-icons" />
      </div>
      <div class="legal-links">
        <a href="/privacy-policy">{SITE_INFO.footer.privacyPolicy}</a>
        <span class="dot">·</span>
        <a href="/terms-and-conditions">{SITE_INFO.footer.termsAndConditions}</a>
      </div>
    </div>

    {/* 3. 저작권 표시 */}
    <div class="footer-bottom">
      <p class="copyright">
        &copy; {SITE_INFO.footer.startYear} - {currentYear} 
        <strong>{SITE_INFO.footer.copyrightHolder}</strong>. 
        All Rights Reserved.
      </p>
    </div>
  </div>
</footer>

<style is:inline>
  .footer-wrapper {
    width: 100%;
    background-color: #ffffff; /* ✅ 검은색 치우고 깨끗한 흰색으로! */
    border-top: 1px solid #f0f0f0;
    padding: 4rem 0 2rem 0;
    margin-top: 6rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  .footer-logo-link {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    justify-content: center;
  }

  .brand-main { color: #111; font-weight: 800; font-size: 1.3rem; }
  .brand-sub { color: #888; font-size: 1.1rem; }
  .footer-tagline { color: #999; font-size: 0.9rem; margin-top: 0.5rem; text-align: center; }

  .footer-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
  }

  /* 소셜 아이콘 스타일 */
  .footer-icons {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .legal-links {
    display: flex;
    gap: 10px;
    font-size: 0.85rem;
    color: #666;
  }

  .legal-links a {
    color: #666;
    text-decoration: none;
    transition: color 0.2s;
  }

  .legal-links a:hover { color: #007bff; }

  .footer-bottom {
    width: 100%;
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid #f8f8f8;
  }

  .copyright {
    color: #bbb;
    font-size: 0.8rem;
    margin: 0;
  }

  .copyright strong { color: #888; }

  @media (max-width: 767px) {
    .footer-wrapper { padding: 3rem 0 1.5rem 0; }
  }
</style>
