---
// [src/components/Footer.astro]
import { Image } from 'astro:assets';
import SocialLinks from '../constants/socialLinks'
import logo from '../assets/logo.png'
import { SITE_INFO } from '../constants/siteConfig';

// ✅ 연도를 수동으로 안 바꿔도 되게 올해 연도를 가져옵니다.
const currentYear = new Date().getFullYear();
---

<footer class="footer-wrapper">
  <div class="footer-container">
    {/* 1. 상단 섹션: 로고 및 설명 */}
    <div class="footer-brand">
      <a href="/" class="footer-logo-link">
        <Image
          class="footer-logo"
          src={logo}
          alt={`${SITE_INFO.title.main}${SITE_INFO.title.sub} 로고`}
          width={40}
          height={40}
        />
        <div class="logo-text">
          <span class="brand-main">{SITE_INFO.title.main}</span>
          <span class="brand-sub">{SITE_INFO.title.sub}</span>
        </div>
      </a>
      <p class="footer-tagline">{SITE_INFO.metadata.tagline}</p>
    </div>

    {/* 2. 중단 섹션: 소셜 링크 및 정책 링크 */}
    <div class="footer-nav">
      <div class="social-box">
        <SocialLinks client:load styleClass="footer-social-icons" />
      </div>
      
      <div class="policy-links">
        <a href="/privacy-policy">{SITE_INFO.footer.privacyPolicy}</a>
        <span class="divider">|</span>
        <a href="/terms-and-conditions">{SITE_INFO.footer.termsAndConditions}</a>
      </div>
    </div>

    {/* 3. 하단 섹션: 저작권 표시 */}
    <div class="footer-bottom">
      <p class="copyright">
        &copy; {SITE_INFO.footer.startYear} - {currentYear} 
        <strong>{SITE_INFO.footer.copyrightHolder}</strong>. 
        {SITE_INFO.footer.allRightsReserved}
      </p>
    </div>
  </div>
</footer>

<style is:inline>
  .footer-wrapper {
    width: 100%;
    background-color: #ffffff;
    border-top: 1px solid #f0f0f0;
    padding: 3rem 0 2rem 0;
    margin-top: 5rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  /* 브랜드 섹션 */
  .footer-logo-link {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    margin-bottom: 0.5rem;
  }
  .brand-main { color: #222; font-weight: 800; font-size: 1.2rem; }
  .brand-sub { color: #666; font-size: 1rem; }
  .footer-tagline { color: #888; font-size: 0.9rem; margin: 0; }

  /* 네비게이션 및 소셜 */
  .footer-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
  }

  .social-box {
    padding: 0.5rem 0;
  }

  .policy-links {
    display: flex;
    align-items: center;
    gap: 15px;
    font-size: 0.85rem;
  }
  .policy-links a {
    color: #666;
    text-decoration: none;
    transition: color 0.2s;
  }
  .policy-links a:hover { color: #007bff; }
  .divider { color: #eee; }

  /* 하단 저작권 */
  .footer-bottom {
    width: 100%;
    text-align: center;
    padding-top: 1.5rem;
    border-top: 1px solid #f9f9f9;
  }
  .copyright {
    color: #999;
    font-size: 0.8rem;
    letter-spacing: 0.3px;
    margin: 0;
  }
  .copyright strong { color: #666; }

  /* 반응형 조절 */
  @media (max-width: 767px) {
    .footer-wrapper { padding: 2.5rem 0 1.5rem 0; }
    .policy-links { flex-direction: column; gap: 8px; }
    .divider { display: none; }
  }
</style>
