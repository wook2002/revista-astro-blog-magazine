---
import { getColor } from '../../utils/heroCategories';
import { resolveImagePath } from '../../utils/imagePath';
import { normalizePostData } from '../../utils/postHelpers';
import type { Post } from '../../utils/getPosts';
// 설정 파일 불러오기
import { SITE_INFO } from '../../constants/siteConfig';

interface Props {
  posts?: Post[];
}

const { posts = [] } = Astro.props;
---

<div class="col-md-4 col-12">
  <h2 class="section-title">{SITE_INFO.featured.popularTitle}</h2>

  <div class="popular-posts">
    {posts.map((post) => {
      const normalized = normalizePostData(post);
      const categoryColor = getColor(post.data.category);

      return (
        <article key={post.id} class="popular-item card-bg card-shadow">
          <div class="card-body">
            <a href={normalized.url}>
              <h3 class="popular-heading">{normalized.title}</h3>
            </a>
            <div class="popular-meta">
              <span class="category" style={`color: ${categoryColor};`}>
                {normalized.category}
              </span>
              <span class="dot">•</span>
              <span>{normalized.readingTime} {SITE_INFO.posts.readingTime}</span>
            </div>
          </div>
        </article>
      );
    })}
  </div>
</div>
