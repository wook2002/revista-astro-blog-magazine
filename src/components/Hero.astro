---
import slugify from 'slugify';
import { categories } from '../utils/heroCategories';
import { SITE_INFO } from '../constants/siteConfig'; // 설정 불러오기
---

<header class="hero-wrapper">
  <div class="hero">
    <div class="row">
      <div class="col-lg-7 col-12 hero-text">
        <h4>{SITE_INFO.hero.eyebrow}</h4>
        <h1>
          <span>{SITE_INFO.hero.titleMain}</span>
          <br /> {SITE_INFO.hero.titleSub}
        </h1>
        <p>{SITE_INFO.hero.description}</p>
      </div>
      <div class="col-lg-5 col-12">
        <div class="hero-categories">
          {categories.map((category, index, arr) => {
            const isLast = arr.length - 1 === index;
            const href = isLast ? '/categories' : `/${slugify(category.category).toLowerCase()}`;
            const styleString = `box-shadow: 0 0 40px; background-color: ${category.color}; color: ${category.color};`;
            
            return (
              <a
                style={styleString}
                class="hero-category"
                href={href}
              >
                <div class="overlay">
                  <div class="category-text-color">
                    {category.category}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  /* 스타일 코드는 동일하므로 생략 (기존 스타일 그대로 두시면 됩니다) */
  .hero-wrapper { border-bottom: 1px solid var(--primary-1); }
  .hero { display: flex; padding: 6rem 0; align-items: center; justify-content: center; max-width: 83vw; margin: 0 auto; }
  /* ... 나머지 스타일 ... */
</style>
