---
import slugify from 'slugify';
import { categories } from '../utils/heroCategories';
import { SITE_INFO } from '../constants/siteConfig';

const translateCategory = (cat: string) => SITE_INFO.categoryMapping[cat] || cat;
---

<header class="hero-wrapper">
  <div class="container">
    {/* ✅ 하단 RecentPosts와 완벽하게 뼈대를 맞춘 부트스트랩 Row/Col 시스템 */}
    <div class="row align-items-center custom-hero-row">
      
      {/* 왼쪽 텍스트 영역 (12칸 중 7칸 차지) */}
      <div class="col-lg-7 col-12 text-side">
        <p class="eyebrow">{SITE_INFO.hero.eyebrow}</p>
        <h1 class="main-title">
          <span class="highlight">{SITE_INFO.hero.titleMain}</span>
          <br />
          <span class="sub-title">{SITE_INFO.hero.titleSub}</span>
        </h1>
        <p class="description">{SITE_INFO.hero.description}</p>
      </div>

      {/* 오른쪽 카테고리 영역 (12칸 중 5칸 차지) - 이제 허허벌판으로 도망가지 않습니다 */}
      <div class="col-lg-5 col-12 category-side">
        <div class="category-grid">
          {categories.map((category) => (
            <a href={`/${slugify(category.category).toLowerCase()}`} class="category-pill" style={`--accent-color: ${category.color}`}>
              <span class="dot"></span>
              <span class="name">{translateCategory(category.category)}</span>
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>
</header>

<style is:inline>
  .hero-wrapper { background-color: #fff; padding: 6rem 0 4rem; border-bottom: 1px solid #f5f5f5; }
  
  /* 모바일에서 위아래 간격 추가 */
  .custom-hero-row { gap: 2rem 0; }

  .eyebrow { color: #007bff; font-weight: 700; font-size: 0.9rem; margin-bottom: 1rem; letter-spacing: 1px; }
  .main-title { font-size: 3.5rem; line-height: 1.1; font-weight: 800; color: #111; margin-bottom: 1.5rem; letter-spacing: -1px; }
  .description { font-size: 1.15rem; color: #636e72; line-height: 1.6; max-width: 90%; }
  
  .category-grid { display: flex; flex-wrap: wrap; gap: 12px; }
  .category-pill { display: flex; align-items: center; gap: 8px; padding: 10px 20px; background: #fff; border: 1px solid #eee; border-radius: 50px; text-decoration: none; transition: all 0.2s ease; }
  .category-pill:hover { border-color: var(--accent-color); transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0,0,0,0.05); }
  .category-pill .dot { width: 8px; height: 8px; border-radius: 50%; background-color: var(--accent-color); }
  .category-pill .name { font-size: 0.95rem; font-weight: 600; color: #444; }

  @media (max-width: 991px) { 
    .text-side { text-align: center; } 
    .description { margin: 0 auto; }
    .category-grid { justify-content: center; margin-top: 1rem; } 
  }
</style>
