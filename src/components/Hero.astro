---
// [src/components/Hero.astro]
import slugify from 'slugify';
import { categories } from '../utils/heroCategories';
import { SITE_INFO } from '../constants/siteConfig';

const translateCategory = (cat: string) => SITE_INFO.categoryMapping[cat] || cat;
---

<header class="hero-wrapper">
  {/* ✅ 하드코딩된 hero-container 대신 sim-container로 교체 */}
  <div class="sim-container">
    <div class="hero-content">
      {/* 1. 텍스트 섹션 */}
      <div class="text-side">
        <p class="eyebrow">{SITE_INFO.hero.eyebrow}</p>
        <h1 class="main-title">
          <span class="highlight">{SITE_INFO.hero.titleMain}</span>
          <br />
          <span class="sub-title">{SITE_INFO.hero.titleSub}</span>
        </h1>
        <p class="description">{SITE_INFO.hero.description}</p>
      </div>

      {/* 2. 카테고리 섹션 */}
      <div class="category-side">
        <div class="category-grid">
          {categories.map((category, index, arr) => {
            const isLast = arr.length - 1 === index;
            const href = isLast ? '/categories' : `/${slugify(category.category).toLowerCase()}`;
            const koreanName = translateCategory(category.category);
            
            return (
              <a href={href} class="category-pill" style={`--accent-color: ${category.color}`}>
                <span class="dot"></span>
                <span class="name">{koreanName}</span>
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</header>

<style is:inline>
  .hero-wrapper {
    background-color: #ffffff;
    padding: 6rem 0 4rem 0;
    border-bottom: 1px solid #f5f5f5;
  }

  /* ✅ .hero-container { max-width... } 로직을 통째로 삭제했습니다. 
     이제 .sim-container가 그 역할을 대신합니다. */

  .hero-content {
    display: grid;
    /* ✅ 사이드바(8:4)와 라인을 맞추기 위한 비율 유지 */
    grid-template-columns: 1.6fr 0.9fr; 
    gap: 4rem;
    align-items: center;
  }

  .eyebrow { color: #007bff; font-weight: 700; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1rem; }
  .main-title { font-size: 3.5rem; line-height: 1.1; font-weight: 800; color: #2d3436; margin-bottom: 1.5rem; }
  .highlight { color: #111; }
  .sub-title { color: #636e72; font-weight: 600; }
  .description { font-size: 1.2rem; color: #636e72; line-height: 1.6; max-width: 500px; }

  .category-grid { display: flex; flex-wrap: wrap; gap: 12px; }
  .category-pill {
    display: flex; align-items: center; gap: 8px; padding: 10px 20px;
    background: #ffffff; border: 1px solid #eee; border-radius: 50px;
    text-decoration: none; transition: all 0.2s ease;
  }
  .category-pill .dot { width: 8px; height: 8px; border-radius: 50%; background-color: var(--accent-color); }
  .category-pill .name { font-size: 0.95rem; font-weight: 600; color: #444; }
  .category-pill:hover { border-color: var(--accent-color); transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0,0,0,0.05); }

  @media (max-width: 991px) {
    .hero-content { 
      grid-template-columns: 1fr; 
      text-align: center; 
      gap: 3rem; 
    }
    .description { margin: 0 auto; }
    .category-grid { justify-content: center; }
    .main-title { font-size: 2.5rem; }
  }
</style>
