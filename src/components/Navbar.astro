---
// [src/components/Navbar.astro]
import { SITE_INFO } from '../constants/siteConfig';

// ✅ 1. 이미지를 직접 import 합니다. (이미지가 src/assets/ 폴더에 있어야 합니다)
// 만약 파일 이름이 다르면(예: Logo.png) 아래 이름을 파일과 똑같이 맞춰주세요.
import logoImg from '../assets/logo.png';
import heartImg from '../assets/heart.png';

const { navLinks, title, navButton } = SITE_INFO;

// 이미지가 성공적으로 불러와졌는지 확인하고 경로를 결정합니다.
const finalLogo = logoImg?.src || "/logo.png";
const finalHeart = heartImg?.src || "/heart.png";
---

<header class="navbar-wrapper">
  {/* ✅ 2. 0.001초의 깜빡임도 허용하지 않는 인라인 스타일 */}
  <style is:inline>
    .navbar-wrapper { width: 100%; background: #fff; border-bottom: 1px solid #eee; position: sticky; top: 0; z-index: 100; }
    .nav-center { display: flex; align-items: center; justify-content: space-between; max-width: 1200px; margin: 0 auto; padding: 0.8rem 1rem; }
    .nav-header { display: flex; align-items: center; gap: 12px; }
    .nav-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }
    .logo-text { display: flex; flex-direction: column; line-height: 1.1; }
    .nav-word-open { color: #333; font-weight: 800; font-size: 1.4rem; }
    .nav-word-ed { color: #555; font-size: 1.2rem; }
    .nav-links { display: flex; list-style: none; gap: 2rem; margin: 0; padding: 0; }
    .nav-links li::before { content: none !important; }
    .page-link { text-decoration: none; color: #444; font-weight: 500; font-size: 1rem; transition: color 0.2s; }
    .page-link:hover { color: #007bff; }
    .support-us-link { display: flex; align-items: center; gap: 8px; text-decoration: none; color: #444; font-weight: 600; padding: 8px 16px; border-radius: 50px; background: #f8f9fa; }
    .toggle-btn { display: none; background: none; border: none; cursor: pointer; }
    
    @media (max-width: 991px) {
      .nav-links, .support-us-link { display: none; }
      .toggle-btn { display: block; }
    }
  </style>

  <nav class="navbar">
    <div class="nav-center">
      <div class="nav-header">
        <a href="/" class="nav-logo not-blue">
          {/* ✅ 3. 최적화된 이미지 경로 적용 */}
          <img src={finalLogo} alt="로고" width="45" height="45" style="object-fit: contain;" />
          <div class="logo-text">
            <span class="nav-word-open">{title.main}</span>
            <span class="nav-word-ed">{title.sub}</span>
          </div>
        </a>
      </div>

      <ul class="nav-links">
        {navLinks.map((link) => (
          <li><a href={link.url} class="page-link">{link.text}</a></li>
        ))}
      </ul>

      <div style="display: flex; align-items: center; gap: 15px;">
        <a class="support-us-link not-blue" href={navButton.url}>
          <img src={finalHeart} alt="" width="20" height="20" />
          {navButton.text}
        </a>
        <button class="toggle-btn" id="menu-toggle">
          <svg viewBox="0 0 512 512" height="30" width="30" fill="#333"><path d="M32 96v64h448V96H32zm0 128v64h448v-64H32zm0 128v64h448v-64H32z"></path></svg>
        </button>
      </div>
    </div>
  </nav>

  {/* 모바일 메뉴 오버레이 */}
  <div id="mobile-menu-overlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 999;"></div>
  <aside id="mobile-menu-aside" style="display: none; position: fixed; top: 0; right: 0; width: 280px; height: 100%; background: white; z-index: 1000; padding: 2rem;">
    <button id="menu-close" style="position: absolute; top: 20px; right: 20px; border: none; background: none; font-size: 1.5rem;">✕</button>
    <ul style="list-style: none; padding: 0; margin-top: 3rem;">
      {navLinks.map((link) => (
        <li style="margin-bottom: 1.5rem;"><a href={link.url} style="text-decoration: none; color: #333; font-size: 1.1rem;">{link.text}</a></li>
      ))}
    </ul>
  </aside>
</header>

<script>
  // 모바일 메뉴 작동 로직
  const toggleBtn = document.getElementById('menu-toggle');
  const closeBtn = document.getElementById('menu-close');
  const overlay = document.getElementById('mobile-menu-overlay');
  const aside = document.getElementById('mobile-menu-aside');

  toggleBtn?.addEventListener('click', () => {
    if(overlay && aside) { overlay.style.display = 'block'; aside.style.display = 'block'; }
  });
  
  const closeMenu = () => {
    if(overlay && aside) { overlay.style.display = 'none'; aside.style.display = 'none'; }
  };

  closeBtn?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);
</script>
