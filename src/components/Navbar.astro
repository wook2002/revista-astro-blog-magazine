---
// [src/components/Navbar.astro]
import { SITE_INFO } from '../constants/siteConfig';
// import logo from '../assets/logo.png';
// import heart from '../assets/heart.png';

const { navLinks, title, navButton } = SITE_INFO;
---

// 경로를 직접 변수에 담습니다 (public 폴더 기준)
const logoSrc = "/logo.png"; 
const heartSrc = "/heart.png";

<header class="navbar-wrapper">
  {/* ✅ 중요: 스타일을 인라인으로 포함시켜 0.001초의 깜빡임도 차단 */}
  <style is:inline>
    .navbar-wrapper { width: 100%; background: #fff; }
    .nav-center { display: flex; align-items: center; justify-content: space-between; max-width: 1200px; margin: 0 auto; padding: 1rem; }
    .nav-links { display: flex; list-style: none; gap: 2rem; margin: 0; padding: 0; }
    .nav-links li { margin: 0; }
    /* 아까 스샷에 보이던 '점'들을 여기서 미리 없애버립니다 */
    .nav-links li::before { content: none !important; } 
    .page-link { text-decoration: none; color: #333; font-weight: 500; }
    
    /* 모바일에서는 일단 숨김 (깜빡임 방지) */
    @media (max-width: 991px) {
      .nav-links { display: none; }
    }
  </style>

  <nav class="navbar">
    <div class="nav-center">
      <div class="nav-header">
        <a href="/" class="nav-logo not-blue">
          <img src={logo.src} alt="로고" width="100" height="100" />
          <div class="logo-text">
            <span class="nav-word-open">{title.main}</span>
            <span class="nav-word-ed">{title.sub}</span>
          </div>
        </a>
        <button class="toggle-btn" id="menu-toggle">
          <svg viewBox="0 0 512 512" height="1em" width="1em"><path d="M32 96v64h448V96H32zm0 128v64h448v-64H32zm0 128v64h448v-64H32z"></path></svg>
        </button>
      </div>

      <ul class="nav-links">
        {navLinks.map((link) => (
          <li><a href={link.url} class="page-link">{link.text}</a></li>
        ))}
      </ul>

      <a class="support-us-link not-blue" href={navButton.url}>
        <img src={heart.src} alt="" class="support-heart" width="19" height="19" />
        {navButton.text}
      </a>
    </div>
  </nav>

  <aside class="mobile-menu" id="mobile-menu">
    <div class="sidebar-container">
      <button class="close-btn" id="menu-close">✕</button>
      <ul class="sidebar-links">
        {navLinks.map((link) => (
          <li><a href={link.url}>{link.text}</a></li>
        ))}
      </ul>
    </div>
  </aside>
</header>

<script>
  const toggleBtn = document.getElementById('menu-toggle');
  const closeBtn = document.getElementById('menu-close');
  const mobileMenu = document.getElementById('mobile-menu');

  toggleBtn?.addEventListener('click', () => mobileMenu?.classList.add('show-sidebar'));
  closeBtn?.addEventListener('click', () => mobileMenu?.classList.remove('show-sidebar'));
</script>
