---
// [src/components/Navbar.astro]
import { SITE_INFO } from '../constants/siteConfig';
import logoImg from '../assets/logo.png';
import heartImg from '../assets/heart.png';

const { navLinks, title, navButton } = SITE_INFO;

const finalLogo = logoImg?.src || "/logo.png";
const finalHeart = heartImg?.src || "/heart.png";
---

<header class="navbar-wrapper">
  <style is:inline>
    /* 1. 기본 구조 및 최상단 고정 */
    .navbar-wrapper { 
      width: 100%; 
      background: rgba(255, 255, 255, 0.95); 
      backdrop-filter: blur(10px); /* 뒷배경 살짝 비치는 효과 */
      border-bottom: 1px solid #f0f0f0; 
      position: sticky; 
      top: 0; 
      z-index: 1000; 
    }
    .nav-center { 
      display: flex; 
      align-items: center; 
      justify-content: space-between; 
      max-width: 1200px; 
      margin: 0 auto; 
      padding: 0.8rem 1.5rem; 
    }
    .nav-header { display: flex; align-items: center; gap: 12px; }
    .nav-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; transition: opacity 0.2s; }
    .nav-logo:hover { opacity: 0.8; }
    .logo-text { display: flex; flex-direction: column; line-height: 1.1; }
    .nav-word-open { color: #2d3436; font-weight: 800; font-size: 1.4rem; letter-spacing: -0.5px; }
    .nav-word-ed { color: #636e72; font-size: 1.1rem; }

    /* 2. 데스크탑 메뉴 */
    .nav-links { display: flex; list-style: none; gap: 2.5rem; margin: 0; padding: 0; }
    .nav-links li::before { content: none !important; }
    .page-link { 
      text-decoration: none; 
      color: #2d3436; 
      font-weight: 600; 
      font-size: 1rem; 
      transition: all 0.2s ease;
      position: relative;
    }
    .page-link:hover { color: #0984e3; }
    
    /* 3. 우측 버튼 그룹 */
    .nav-right { display: flex; align-items: center; gap: 1.2rem; }
    .support-us-link { 
      display: flex; 
      align-items: center; 
      gap: 8px; 
      text-decoration: none; 
      color: #d63031; 
      font-weight: 700; 
      padding: 10px 20px; 
      border-radius: 50px; 
      background: #fff5f5; 
      transition: all 0.3s ease;
      border: 1px solid transparent;
    }
    .support-us-link:hover { background: #fab1a0; color: #fff; transform: translateY(-2px); }
    
    /* 4. 토글 버튼 (마우스 손가락 추가) */
    .toggle-btn { 
      display: none; 
      background: none; 
      border: none; 
      cursor: pointer; /* ✅ 마우스 손가락 모양 */
      padding: 8px;
      color: #2d3436;
      transition: transform 0.2s;
    }
    .toggle-btn:hover { transform: scale(1.1); }

    /* 5. 모바일 사이드바 (애니메이션 입히기) */
    #mobile-menu-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.4); 
      z-index: 1100; opacity: 0; visibility: hidden; 
      transition: all 0.4s ease; backdrop-filter: blur(2px);
    }
    #mobile-menu-aside {
      position: fixed; top: 0; right: 0; width: 300px; height: 100%; 
      background: white; z-index: 1200; padding: 2.5rem;
      transform: translateX(100%); /* 처음엔 오른쪽 밖에 숨김 */
      transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); /* 부드러운 가속도 */
      box-shadow: -10px 0 30px rgba(0,0,0,0.05);
    }
    /* 메뉴 열렸을 때 상태 */
    .menu-active #mobile-menu-overlay { opacity: 1; visibility: visible; }
    .menu-active #mobile-menu-aside { transform: translateX(0); }

    /* 사이드바 내부 디자인 */
    #menu-close { 
      position: absolute; top: 25px; right: 25px; 
      border: none; background: none; font-size: 2rem; 
      cursor: pointer; color: #636e72; transition: color 0.2s;
    }
    #menu-close:hover { color: #d63031; }
    .sidebar-links { list-style: none; padding: 0; margin-top: 4rem; }
    .sidebar-links li { margin-bottom: 1.8rem; border-bottom: 1px solid #f8f9fa; padding-bottom: 0.8rem; }
    .sidebar-links a { 
      text-decoration: none; color: #2d3436; 
      font-size: 1.25rem; font-weight: 700; display: block;
      transition: padding-left 0.2s;
    }
    .sidebar-links a:hover { padding-left: 10px; color: #0984e3; }

    @media (max-width: 991px) {
      .nav-links, .support-us-link { display: none; }
      .toggle-btn { display: block; }
    }
  </style>

  <nav class="navbar">
    <div class="nav-center">
      <div class="nav-header">
        <a href="/" class="nav-logo not-blue">
          <img src={finalLogo} alt="로고" width="45" height="45" style="object-fit: contain;" />
          <div class="logo-text">
            <span class="nav-word-open">{title.main}</span>
            <span class="nav-word-ed">{title.sub}</span>
          </div>
        </a>
      </div>

      <ul class="nav-links">
        {navLinks.map((link) => (
          <li><a href={link.url} class="page-link">{link.text}</a></li>
        ))}
      </ul>

      <div class="nav-right">
        <a class="support-us-link not-blue" href={navButton.url}>
          <img src={finalHeart} alt="" width="20" height="20" />
          {navButton.text}
        </a>
        <button class="toggle-btn" id="menu-toggle" aria-label="메뉴 열기">
          <svg viewBox="0 0 512 512" height="32" width="32" fill="currentColor"><path d="M32 96v64h448V96H32zm0 128v64h448v-64H32zm0 128v64h448v-64H32z"></path></svg>
        </button>
      </div>
    </div>
  </nav>

  <div id="mobile-menu-overlay"></div>
  <aside id="mobile-menu-aside">
    <button id="menu-close" aria-label="메뉴 닫기">✕</button>
    <ul class="sidebar-links">
      {navLinks.map((link) => (
        <li><a href={link.url}>{link.text}</a></li>
      ))}
      <li style="border: none; margin-top: 3rem;">
        <a href={navButton.url} style="color: #d63031;">{navButton.text}</a>
      </li>
    </ul>
  </aside>
</header>

<script>
  const toggleBtn = document.getElementById('menu-toggle');
  const closeBtn = document.getElementById('menu-close');
  const overlay = document.getElementById('mobile-menu-overlay');
  const body = document.body;

  const openMenu = () => body.classList.add('menu-active');
  const closeMenu = () => body.classList.remove('menu-active');

  toggleBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);
</script>
