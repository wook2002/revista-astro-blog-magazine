---
// [src/components/Sidebar/SidebarCard.astro]
---

<div class="sidebar-card">
  <slot />
</div>

<style is:inline>
  .sidebar-card {
    background: #ffffff;
    border-radius: 12px; /* ✅ 네비바처럼 둥글게 */
    padding: 1.5rem;
    margin-bottom: 2rem;
    border: 1px solid #f0f0f0;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03); /* ✅ 은은한 그림자 */
  }
  .sidebar-card:hover {
    transform: translateY(-5px); /* ✅ 마우스 올리면 살짝 들리는 효과 */
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
  }
</style>
