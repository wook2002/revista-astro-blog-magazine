---
// [src/components/Sidebar/About.astro]
import { Image } from 'astro:assets';
import SocialLinks from '../../constants/socialLinks';
import Title from './Title.astro';
import SidebarCard from './SidebarCard.astro';
import logo from '../../assets/logo.png';
import { SITE_INFO } from '../../constants/siteConfig'; // ✅ 설정 파일 임포트
---

<SidebarCard>
  <div class="about-wrapper">
    <Title title="소개" /> {/* ✅ 제목 한글화 */}
    
    <div class="author-image-container">
      <Image
        src={logo}
        alt="author"
        class="author-img"
        width={100}
        height={100}
      />
    </div>

    <div class="author-text">
      <p class="main-desc">{SITE_INFO.metadata.description}</p>
      <p class="sub-desc">{SITE_INFO.metadata.tagline}</p>
    </div>

    {/* 소셜 링크 섹션 */}
    <div class="social-container">
      <SocialLinks client:load className="sidebar-icons" />
    </div>
  </div>
</SidebarCard>

<style is:inline>
  .about-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.2rem;
  }

  .author-image-container {
    margin: 0.5rem 0;
    padding: 5px;
    border: 1px solid #f0f0f0;
    border-radius: 50%; /* ✅ 이미지를 동그랗게 감싸기 */
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .author-img {
    border-radius: 50%; /* ✅ 이미지 자체도 동그랗게 */
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .author-img:hover {
    transform: scale(1.05) rotate(5deg); /* ✅ 살짝 커지면서 회전하는 위트 */
  }

  .author-text {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .main-desc {
    color: #2d3436;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.5;
    margin: 0;
  }

  .sub-desc {
    color: #636e72;
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0;
  }

  .social-container {
    width: 100%;
    padding-top: 1rem;
    border-top: 1px dashed #eee; /* ✅ 구분선 추가 */
    margin-top: 0.5rem;
  }
</style>
